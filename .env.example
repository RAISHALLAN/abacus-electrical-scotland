# Firebase Configuration
# Get these values from your Firebase project settings
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_DATABASE_URL=your_database_url_here

# Resend Email API (for sending quotes and confirmations)
RESEND_API_KEY=your_resend_api_key_here

# Admin Password (will be hashed and stored in Firebase)
ADMIN_PASSWORD=your_secure_password_here

# Company Details
VITE_COMPANY_NAME=Abacus Electrical Scotland
VITE_COMPANY_EMAIL=info@abacuselectrical.co.uk
VITE_COMPANY_PHONE=your_phone_number_here
VITE_COMPANY_ADDRESS=your_address_here
